# ─────────────────────────────────────────────────────────────────────────────
# Nightshift Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Linear ────────────────────────────────────────────────────────────────────

# Your Linear personal API key
# Get it at: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_xxx

# Your Linear team identifier — the prefix before ticket numbers
# Example: if your tickets are ENG-42, this is "ENG"
LINEAR_TEAM_KEY=ENG

# The Linear column Nightshift watches for new work
# Tickets moved to this state will be picked up automatically
# Must match the state name exactly (case-sensitive)
TRIGGER_STATE=Next

# State set when Nightshift starts working on a ticket
IN_PROGRESS_STATE=In Progress

# State set after the PR is created
IN_REVIEW_STATE=In Review

# ── Repository ────────────────────────────────────────────────────────────────

# Absolute path to the git repository Nightshift will work in
REPO_PATH=/path/to/your/repo

# Base branch for new branches and PRs
MAIN_BRANCH=main

# ── Agent ─────────────────────────────────────────────────────────────────────

# Maximum number of tickets processed at the same time
MAX_CONCURRENT=3

# Seconds between Linear polls
POLL_INTERVAL=30

# Enable Claude Code Agent Teams (experimental multi-agent mode)
# When true: a lead agent plans and coordinates teammate agents in parallel
# When false: single Claude session per ticket (faster, cheaper, less powerful)
USE_AGENT_TEAMS=false

# ── Safety Guards ──────────────────────────────────────────────────────────────

# Max total agent spawns per session — prevents runaway dispatching
MAX_DISPATCHES=10

# Max retry attempts per ticket before skipping until restart
MAX_RETRIES=3

# Max runtime (minutes) per agent — kills the process after this
AGENT_TIMEOUT_MINUTES=45

# ── Gemini Review Gate (optional) ─────────────────────────────────────────────
# Leave GEMINI_API_KEY empty to skip the review gate entirely.
# Get your key at: https://aistudio.google.com/apikey

# Gemini API key — leave empty to disable the review gate
GEMINI_API_KEY=

# Gemini model to use for code review
GEMINI_MODEL=gemini-2.5-pro

# How many fix passes Claude gets after Gemini flags issues
# Set to 0 to create the PR immediately with Gemini's comments attached
MAX_REVIEW_RETRIES=1
