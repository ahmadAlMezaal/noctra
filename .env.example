# ─────────────────────────────────────────────────────────────────────────────
# Noctra Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Linear ────────────────────────────────────────────────────────────────────

# Your Linear personal API key
# Get it at: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_xxx

# OPTIONAL — post as the "Noctra" app (actor=app) instead of the personal user.
# Register an OAuth app at Settings → API → OAuth applications and paste its
# client id + secret. Noctra mints + renews a 30-day app token itself
# (client_credentials grant) — no refresh token, no browser flow, set once.
# Preferred over LINEAR_OAUTH_TOKEN; falls back to LINEAR_API_KEY if the
# credentials ever fail to authenticate.
# LINEAR_OAUTH_CLIENT_ID=
# LINEAR_OAUTH_CLIENT_SECRET=
# LINEAR_OAUTH_SCOPE=read,write
#
# Legacy: a static actor=app access token (expires; degrades to the API key).
# LINEAR_OAUTH_TOKEN=

# Your Linear team identifier — the prefix before ticket numbers
# Example: if your tickets are ENG-42, this is "ENG"
LINEAR_TEAM_KEY=ENG

# Ticket sources to poll. Default is Linear only.
# Use "github" for GitHub Issues, or comma-separate sources: "linear,github".
# TICKET_SOURCES=linear
#
# GitHub Issues source: repos to scan and the label that triggers dispatch.
# The issue's own repo is used as the target repo unless the issue body has
# a `Repo:` directive. A `Branch:` directive in the issue body is also honored.
# GITHUB_ISSUES_REPOS=your-org/your-repo
# GITHUB_TRIGGER_LABEL=noctra

# How Noctra picks up tickets: "state" or "label"
#   state — watches a Linear column (e.g. "Next")
#   label — watches for a label (e.g. "noctra")
# Default: state (current behaviour unchanged)
TRIGGER_MODE=state

# The Linear column Noctra watches for new work (state mode only)
# Tickets moved to this state will be picked up automatically
# Must match the state name exactly (case-sensitive)
TRIGGER_STATE=Next

# The label name Noctra watches for (label mode only)
# Any ticket tagged with this label is picked up, regardless of column
# The label is removed after dispatch so it isn't reprocessed
# TRIGGER_LABEL=noctra

# State set after the PR is created
IN_REVIEW_STATE=In Review

# ── Repositories ──────────────────────────────────────────────────────────────
#
# Noctra picks the target repo per-ticket from the ticket's Linear PROJECT.
# Add a `Repo:` line to the project's description (or content body):
#   Repo: your-org/your-repo
#   Branch: main   (optional — defaults to the repo's default branch)
# owner/name shorthand expands to a GitHub HTTPS URL; full https:// / git@ URLs
# are used verbatim (so SSH and non-GitHub hosts work). Repos are cloned on demand.
#
# REPO_PATH below is an OPTIONAL fallback: it is used only for tickets whose
# Linear project has no `Repo:` directive. Leave it empty if you rely solely on
# directives.

# Optional single-repo fallback — absolute path to a local git repository
REPO_PATH=

# Default base branch for new branches and PRs
# (a project's `Branch:` directive overrides this per-repo)
MAIN_BRANCH=main

# ── Agent ─────────────────────────────────────────────────────────────────────

# Coding-agent backend that implements tickets: "claude" (default), "codex",
# or "copilot".
#   claude  → Anthropic Claude Code CLI (`claude`)
#   codex   → OpenAI Codex CLI (`codex`) — install it and run `codex login` once
#             on the host (ChatGPT subscription or set OPENAI_API_KEY).
#   copilot → GitHub Copilot CLI (`copilot`) — uses your Copilot subscription
#             via `gh` (GH_TOKEN or `gh auth login`).
# Default ("claude") keeps existing behaviour unchanged.
AGENT_BACKEND=claude

# ── Container / headless auth (Docker, CI, any non-logged-in host) ──────────────
# On a logged-in laptop the agent/gh/git already have credentials. In a container
# there's no interactive login, so provide them here — Noctra passes the
# environment through to the CLIs it shells out to. (Ignored if already logged in.)
#
# ANTHROPIC_API_KEY=sk-ant-...        # for AGENT_BACKEND=claude
# OPENAI_API_KEY=sk-...               # for AGENT_BACKEND=codex
# GH_TOKEN=ghp_...                    # gh PR creation + git push (repo + PR scope);
#                                     #   also authenticates AGENT_BACKEND=copilot
# GIT_USER_NAME=Noctra            # commit identity (defaults to a bot)
# GIT_USER_EMAIL=noctra@users.noreply.github.com
#
# Repos are declared per-project in Linear via the `Repo:` directive (see
# above) — there's no registry file or env var to configure, even on PaaS.

# Maximum number of tickets processed at the same time
MAX_CONCURRENT=3

# Seconds between Linear polls
POLL_INTERVAL=30

# Enable Claude Code Agent Teams (experimental multi-agent mode)
# When true: a lead agent plans and coordinates teammate agents in parallel
# When false: single Claude session per ticket (faster, cheaper, less powerful)
USE_AGENT_TEAMS=false

# ── Safety Guards ──────────────────────────────────────────────────────────────

# Max ticket dispatches per UTC day — when hit, new dispatches pause and
# auto-resume after midnight (the process keeps running). A coarse activity
# cap; actual token/$ spend is bounded by the budget caps further below.
MAX_DISPATCHES=10

# Max retry attempts per ticket before skipping until restart
MAX_RETRIES=3

# Max runtime (minutes) per agent — kills the process after this
AGENT_TIMEOUT_MINUTES=45

# ── Budget / Cost Management (optional) ────────────────────────────────────────
# Daily caps — when a cap is hit, Noctra pauses dispatching and auto-resumes
# at the next UTC midnight. Set to 0 (default) for unlimited.

# Maximum tokens per day (across all agent runs). Parsed from CLI output when
# available; not all backends report token counts.
# MAX_DAILY_TOKENS=0

# Maximum estimated cost per day in USD. Parsed from CLI output when available.
# MAX_DAILY_USD=0

# What to do when a rate limit is hit: "pause" (default) or "shutdown".
#   pause    — pause dispatching for RATE_LIMIT_COOLDOWN seconds, then resume
#   shutdown — exit the process (legacy behaviour, pre-ENG-217)
RATE_LIMIT_STRATEGY=pause

# Seconds to pause dispatching after a rate limit (default: 1800 = 30 minutes).
# Only used when RATE_LIMIT_STRATEGY=pause.
# RATE_LIMIT_COOLDOWN=1800

# ── Telegram Notifications (optional) ─────────────────────────────────────────
# Get notified on your phone when PRs are created, tickets fail, or limits are hit.

# Set to true to enable Telegram notifications (default: false)
TELEGRAM_ENABLED=false

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Chat ID to send messages to (use @userinfobot to find yours)
TELEGRAM_CHAT_ID=

# Verbose: also notify on every ticket dispatch/plan/sweep via ALL configured
# notifiers — Telegram, Slack, and Discord — not just Telegram (default: false =
# terminal events only). TELEGRAM_VERBOSE is honored as a deprecated alias.
VERBOSE_NOTIFICATIONS=false

# ── Slack / Discord Notifications (optional) ──────────────────────────────────
# Webhook-based status notifications. A non-empty URL enables the platform —
# there is no separate ENABLED flag. Multiple notifiers can run at once;
# Noctra fans out to every configured backend (Telegram + Slack + Discord).

# Slack incoming-webhook URL (Slack app → Incoming Webhooks → Add to Workspace)
SLACK_WEBHOOK_URL=

# Discord channel webhook URL (Channel → Edit → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=

# ── Gemini Review Gate (optional) ─────────────────────────────────────────────
# GEMINI_MODE controls how Noctra talks to Gemini:
#   api — paid Gemini API using GEMINI_API_KEY (default; existing behaviour)
#   cli — shells out to the gemini CLI using your Google OAuth login
#
# For cli mode, install the Gemini CLI and run `gemini` once on the host to
# complete the one-time Google login. If the CLI is missing or not logged in,
# Noctra skips the optional gate with a clear warning instead of crashing.
#
# Leave GEMINI_API_KEY empty in api mode to skip the review gate entirely.
# Get an API key at: https://aistudio.google.com/apikey
GEMINI_MODE=api

# Gemini API key — used only when GEMINI_MODE=api
GEMINI_API_KEY=

# Gemini model to use for code review (API or CLI mode)
GEMINI_MODEL=gemini-2.5-pro

# How many fix passes Claude gets after Gemini flags issues
# Set to 0 to create the PR immediately with Gemini's comments attached
MAX_REVIEW_RETRIES=1

# ── Auto-iterate on PR Feedback (optional) ───────────────────────────────────
# When enabled, Noctra periodically polls the open PRs it created. New
# comments / reviews, OR a failing CI run, trigger Claude to address them on the
# SAME branch (so the PR just gets a follow-up commit instead of being
# abandoned). Review feedback and CI fixes share the MAX_PR_ITERATIONS budget.

# Set to true to enable. Default off — single-shot behaviour stays unchanged.
AUTO_ITERATE_PRS=false

# Per-PR safety cap. After this many re-engagements on the same PR, Noctra
# stops and asks for human attention (Telegram + Linear comment).
MAX_PR_ITERATIONS=3

# Seconds between PR scans. Less aggressive than the Linear poll because PR
# events are rarer.
PR_POLL_INTERVAL=120

# Comma-separated GitHub logins / bot names whose feedback Noctra will
# act on. Humans are always trusted; bots have to be explicitly listed.
# Empty = humans only — the safe default after a bot reviewer was confidently
# wrong about a config file (see PR #50).
# Example: gemini-code-assist,coderabbit
TRUSTED_REVIEWERS=

# ── Autonomous maintenance sweeps (optional, off by default) ──
# Runs maintenance tasks across cloned repos on a schedule and opens PRs.
SWEEP_ENABLED=false
# Comma-separated subset of tasks; empty = all registered tasks in
# internal/sweep (e.g. lint-cleanup, dead-code).
SWEEP_TASKS=
# Comma-separated repos to sweep (owner/name or git URLs, cloned on demand).
# Empty = every repo Noctra has already cloned from tickets.
SWEEP_REPOS=
# When to run: a cron expression (e.g. "0 0 * * *" = every day at midnight).
# Empty = use the fixed SWEEP_INTERVAL below instead.
SWEEP_SCHEDULE=
# Fallback fixed cadence in seconds when SWEEP_SCHEDULE is empty (86400 = 24h).
SWEEP_INTERVAL=86400
# Max tasks dispatched per sweep cycle.
SWEEP_MAX_TASKS=5

# Where Noctra persists PR cursors, sweep cooldowns, OAuth, and history.
# Defaults to $HOME/.noctra/state.db.
# STATE_DB=

# Legacy JSON state file used as a one-time migration source when STATE_DB is
# first created. Defaults to $HOME/.noctra-state.json.
# STATE_FILE=
